<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NoteNest</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/nodenest.css">
</head>
<body>
<div class="main-container">
    <div class="sidebar">
        <div>
            <h1 class="logo">NoteNest</h1>
                <a href="/nodenest/new" class="new-note-btn">+ New Note</a>
            <div class="menu">
                <div class="menu-item active">
                    All Notes
                </div>
                <div class="menu-item">
                    Favorites
                </div>
                <div class="menu-item">
                    Trash
                </div>
            </div>
        </div>
        <div class="profile-box">
            <h5>Jayesh Choudhary</h5>
            <p>NoteNest User</p>
        </div>
    </div>
    <div class="content">
        <div class="topbar">
            <input type="text" placeholder="Search notes..." class="search-bar">
        </div>
        <div class="heading-section">
            <h1>All Notes</h1>
            <p><%= notes.length %> notes</p>
        </div>
        <div class="notes-grid">
            <% for(let note of notes) { %>
                <div class="note-card">
                    <div class="card-top">
                        <h3><%= note.title %></h3>
                    </div>
                    <p class="note-description">
                        <%= note.description %>
                    </p>
                    <div class="card-footer">
                        <span>
                            <%= note.created_at.toDateString() %>
                        </span>
                    </div>
                    <form action="/nodenest/<%= note._id %>?_method=DELETE" method="post">
                        <button class="delete-btn">Delete</button>
                    </form>
                    <form action="/nodenest/<%=note._id%>/edit" method="get">
                        <button class="delete-btn">Edit</button>
                    </form>
                </div>
            <% } %>
        </div>
    </div>
</div>
</body>
</html>