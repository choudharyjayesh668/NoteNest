<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Note</title>
    <link rel="stylesheet" href="/css/newnote.css">
</head>
<body>
<div class="container">
    <div class="note-box">
        <h1>Create New Note</h1>
        <p>Write and save your thoughts</p>
        <form action="/nodenest/new" method="post">
            <input type="text" name="title" placeholder="Enter note title" class="input-box">
            <textarea name="description" placeholder="Write your note here..." class="textarea-box"></textarea>
            <button type="submit">Save Note</button>
        </form>
    </div>
</div>
</body>
</html>